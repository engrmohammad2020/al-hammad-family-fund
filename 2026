<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>صندوق عائلة الحماد</title>
    
    <!-- الخطوط -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- الأيقونات -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- المكتبات (تمت إزالة Moment.js واستخدام التقويم المدمج لتسريع التطبيق) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Cairo', 'sans-serif'] },
                    colors: {
                        green: { 500: '#22c55e', 600: '#16a34a', 700: '#15803d' }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: #f3f4f6; }
        .fade-enter-active, .fade-leave-active { transition: opacity 0.3s ease; }
        .fade-enter-from, .fade-leave-to { opacity: 0; }
        .glass-card { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
        .no-spinners::-webkit-outer-spin-button,
        .no-spinners::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .no-spinners { -moz-appearance: textfield; }
    </style>
</head>
<body class="text-gray-800 antialiased">
    <div id="app" class="min-h-screen flex flex-col">
        <!-- الهيدر -->
        <header class="bg-gradient-to-r from-green-700 to-green-500 text-white shadow-lg">
            <div class="container mx-auto px-4 py-4 flex justify-between items-center">
                <div class="flex items-center space-x-3 space-x-reverse">
                    <!-- تم إضافة الشعار المرفق هنا -->
                    <img src="sh-r-lHmd.jpg" alt="شعار صندوق عائلة الحماد" class="h-14 w-14 object-contain bg-white rounded-xl shadow-md p-1">
                    <h1 class="text-2xl font-bold">صندوق عائلة الحماد</h1>
                </div>
                <div class="text-sm bg-white/20 px-4 py-2 rounded-full backdrop-blur-sm">
                    <i class="fas fa-calendar-alt ml-2"></i>{{ currentHijriDate }}
                </div>
            </div>
        </header>

        <!-- التبويبات -->
        <nav class="bg-white shadow">
            <div class="container mx-auto px-4 flex space-x-2 space-x-reverse overflow-x-auto py-2">
                <button v-for="tab in tabs" :key="tab.id" @click="activeTab = tab.id"
                    :class="['px-5 py-3 rounded-lg font-semibold transition-all duration-300 whitespace-nowrap', 
                    activeTab === tab.id ? 'bg-green-100 text-green-700 shadow-sm' : 'text-gray-500 hover:bg-gray-50']">
                    <i :class="tab.icon + ' ml-2'"></i> {{ tab.name }}
                </button>
            </div>
        </nav>

        <!-- المحتوى -->
        <main class="container mx-auto px-4 py-8 flex-grow">
            <transition name="fade" mode="out-in">
                <!-- 1. لوحة القيادة -->
                <div v-if="activeTab === 'dashboard'" key="dash">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <div class="glass-card p-6 rounded-2xl shadow-sm border-r-4 border-green-500">
                            <div class="flex justify-between items-center">
                                <div>
                                    <p class="text-gray-500 text-sm">إجمالي الأعضاء</p>
                                    <h3 class="text-3xl font-bold text-gray-800 mt-1">{{ stats.total }}</h3>
                                </div>
                                <div class="bg-green-100 p-3 rounded-full text-green-600"><i class="fas fa-users text-xl"></i></div>
                            </div>
                        </div>
                        <div class="glass-card p-6 rounded-2xl shadow-sm border-r-4 border-blue-500">
                            <div class="flex justify-between items-center">
                                <div>
                                    <p class="text-gray-500 text-sm">الذكور</p>
                                    <h3 class="text-3xl font-bold text-gray-800 mt-1">{{ stats.males }}</h3>
                                </div>
                                <div class="bg-blue-100 p-3 rounded-full text-blue-600"><i class="fas fa-male text-xl"></i></div>
                            </div>
                        </div>
                        <div class="glass-card p-6 rounded-2xl shadow-sm border-r-4 border-pink-500">
                            <div class="flex justify-between items-center">
                                <div>
                                    <p class="text-gray-500 text-sm">الإناث</p>
                                    <h3 class="text-3xl font-bold text-gray-800 mt-1">{{ stats.females }}</h3>
                                </div>
                                <div class="bg-pink-100 p-3 rounded-full text-pink-600"><i class="fas fa-female text-xl"></i></div>
                            </div>
                        </div>
                        <div class="glass-card p-6 rounded-2xl shadow-sm border-r-4 border-purple-500">
                            <div class="flex justify-between items-center">
                                <div>
                                    <p class="text-gray-500 text-sm">آخر تحديث للبيانات</p>
                                    <h3 class="text-sm font-bold text-gray-800 mt-2">{{ stats.lastUpdate }}</h3>
                                </div>
                                <div class="bg-purple-100 p-3 rounded-full text-purple-600"><i class="fas fa-clock text-xl"></i></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. إضافة عضو -->
                <div v-else-if="activeTab === 'add'" key="add" class="glass-card p-8 rounded-2xl shadow-sm">
                    <h2 class="text-2xl font-bold text-green-700 mb-6 border-b pb-4"><i class="fas fa-user-plus ml-2"></i>إضافة عضو جديد</h2>
                    <form @submit.prevent="saveMember" class="space-y-6">
                        <!-- الاسم الرباعي -->
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                            <div><label class="block text-sm font-semibold mb-1">الاسم الأول *</label><input v-model="form.firstName" required class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"></div>
                            <div><label class="block text-sm font-semibold mb-1">اسم الأب *</label><input v-model="form.fatherName" required class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"></div>
                            <div><label class="block text-sm font-semibold mb-1">اسم الجد</label><input v-model="form.grandName" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"></div>
                            <div><label class="block text-sm font-semibold mb-1">العائلة *</label><input v-model="form.familyName" required class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"></div>
                        </div>

                        <!-- المعلومات الأساسية -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-sm font-semibold mb-1">الجنس *</label>
                                <select v-model="form.gender" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none">
                                    <option value="ذكر">ذكر</option>
                                    <option value="أنثى">أنثى</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold mb-1">فصيلة الدم</label>
                                <select v-model="form.bloodType" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none">
                                    <option v-for="bt in ['O+', 'O-', 'A+', 'A-', 'B+', 'B-', 'AB+', 'AB-']" :value="bt">{{ bt }}</option>
                                </select>
                            </div>
                            <!-- تاريخ الميلاد -->
                            <div>
                                <label class="block text-sm font-semibold mb-1">تاريخ الميلاد</label>
                                <div class="flex flex-col space-y-2">
                                    <select v-model="form.dobType" class="p-2 border rounded-lg w-full focus:ring-2 focus:ring-green-400 outline-none">
                                        <option value="هجري">هجري</option>
                                        <option value="ميلادي">ميلادي</option>
                                    </select>
                                    
                                    <!-- التقويم الهجري المخصص -->
                                    <div v-if="form.dobType === 'هجري'" class="flex space-x-2 space-x-reverse">
                                        <select v-model="form.dobHijri.day" class="p-2 border rounded-lg w-1/4 outline-none bg-gray-50">
                                            <option v-for="d in 30" :key="d" :value="d">{{ d }}</option>
                                        </select>
                                        <select v-model="form.dobHijri.month" class="p-2 border rounded-lg w-2/4 outline-none bg-gray-50">
                                            <option v-for="m in hijriMonths" :key="m" :value="m">{{ m }}</option>
                                        </select>
                                        <select v-model="form.dobHijri.year" class="p-2 border rounded-lg w-1/4 outline-none bg-gray-50">
                                            <option v-for="y in hijriYears" :key="y" :value="y">{{ y }}</option>
                                        </select>
                                    </div>
                                    
                                    <!-- التقويم الميلادي المخصص -->
                                    <div v-else class="flex space-x-2 space-x-reverse">
                                        <select v-model="form.dobGregorian.day" class="p-2 border rounded-lg w-1/4 outline-none bg-gray-50">
                                            <option v-for="d in 31" :key="d" :value="d">{{ d }}</option>
                                        </select>
                                        <select v-model="form.dobGregorian.month" class="p-2 border rounded-lg w-2/4 outline-none bg-gray-50">
                                            <option v-for="m in gregorianMonths" :key="m" :value="m">{{ m }}</option>
                                        </select>
                                        <select v-model="form.dobGregorian.year" class="p-2 border rounded-lg w-1/4 outline-none bg-gray-50">
                                            <option v-for="y in gregorianYears" :key="y" :value="y">{{ y }}</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- معلومات الاتصال والحالة -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-sm font-semibold mb-1">رقم الهوية (السجل المدني)</label>
                                <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="10" v-model="form.nationalId" placeholder="بدون مسافات (10 أرقام)" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none no-spinners">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold mb-1">رقم الهاتف</label>
                                <input type="text" inputmode="tel" v-model="form.phone" placeholder="مثال: 05XXXXXXXX" dir="ltr" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none text-right">
                            </div>
                            <div><label class="block text-sm font-semibold mb-1">المهنة</label><input v-model="form.profession" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"></div>
                        </div>

                        <!-- الحالة الاجتماعية والأبناء -->
                        <div class="p-5 bg-gray-50 rounded-lg border">
                            <label class="block text-sm font-semibold mb-2">الحالة الاجتماعية</label>
                            <select v-model="form.maritalStatus" class="w-full md:w-1/3 p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none">
                                <option value="أعزب">أعزب</option>
                                <option value="متزوج">متزوج</option>
                                <option value="مطلق">مطلق</option>
                                <option value="أرمل">أرمل</option>
                            </select>

                            <div v-if="form.maritalStatus !== 'أعزب'" class="grid grid-cols-3 gap-4 border-t border-gray-200 mt-4 pt-4">
                                <div>
                                    <label class="block text-sm font-semibold mb-1 text-blue-700">عدد البنين</label>
                                    <input type="number" min="0" v-model="form.maleChildren" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-400 outline-none">
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold mb-1 text-pink-700">عدد البنات</label>
                                    <input type="number" min="0" v-model="form.femaleChildren" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-pink-400 outline-none">
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold mb-1 text-green-700">مجموع الأبناء (تلقائي)</label>
                                    <input type="number" readonly :value="totalChildren" class="w-full p-2 border rounded-lg bg-green-100 text-green-800 font-bold cursor-not-allowed outline-none no-spinners">
                                </div>
                            </div>
                        </div>

                        <!-- العنوان والملاحظات -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-sm font-semibold mb-1">العنوان / مكان الإقامة</label><textarea v-model="form.address" rows="3" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"></textarea></div>
                            <div><label class="block text-sm font-semibold mb-1">ملاحظات إضافية</label><textarea v-model="form.notes" rows="3" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"></textarea></div>
                        </div>

                        <div class="text-left">
                            <button type="submit" class="bg-gradient-to-r from-green-600 to-green-500 hover:from-green-700 hover:to-green-600 text-white px-8 py-3 rounded-lg font-bold shadow-md transition-all">
                                <i class="fas fa-save ml-2"></i> حفظ بيانات العضو
                            </button>
                        </div>
                    </form>
                </div>

                <!-- 3. قائمة الأعضاء -->
                <div v-else-if="activeTab === 'list'" key="list" class="glass-card p-8 rounded-2xl shadow-sm">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-2xl font-bold text-green-700"><i class="fas fa-list ml-2"></i>سجل العائلة</h2>
                        <input type="text" v-model="searchQuery" placeholder="بحث بالاسم، الهوية، الجوال..." class="p-2 border rounded-lg w-64 focus:ring-2 focus:ring-green-400 outline-none shadow-sm">
                    </div>
                    
                    <div class="overflow-x-auto rounded-lg border">
                        <table class="w-full text-right" id="membersTable">
                            <thead class="bg-green-50 text-green-800 border-b">
                                <tr>
                                    <th class="p-3">الاسم الكامل</th>
                                    <th class="p-3">الجنس</th>
                                    <th class="p-3">رقم الهاتف</th>
                                    <th class="p-3">الحالة الاجتماعية</th>
                                    <th class="p-3 text-center">الإجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="member in filteredMembers" :key="member.id" class="border-b hover:bg-gray-50 transition-colors">
                                    <td class="p-3 font-semibold">{{ member.firstName }} {{ member.fatherName }} {{ member.grandName }} {{ member.familyName }}</td>
                                    <td class="p-3"><span :class="member.gender === 'ذكر' ? 'text-blue-600' : 'text-pink-600'">{{ member.gender }}</span></td>
                                    <td class="p-3 text-left" dir="ltr">{{ member.phone || '-' }}</td>
                                    <td class="p-3">{{ member.maritalStatus }}</td>
                                    <td class="p-3 text-center space-x-2 space-x-reverse">
                                        <button @click="viewMember(member)" class="text-blue-500 hover:text-blue-700"><i class="fas fa-eye"></i></button>
                                        <button @click="deleteMember(member.id)" class="text-red-500 hover:text-red-700"><i class="fas fa-trash"></i></button>
                                    </td>
                                </tr>
                                <tr v-if="filteredMembers.length === 0">
                                    <td colspan="5" class="p-6 text-center text-gray-500">لا توجد بيانات مطابقة للبحث</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- 4. استيراد وتصدير -->
                <div v-else-if="activeTab === 'export'" key="export" class="glass-card p-8 rounded-2xl shadow-sm">
                    <h2 class="text-2xl font-bold text-green-700 mb-6 border-b pb-4"><i class="fas fa-file-export ml-2"></i>النسخ الاحتياطي والتقارير</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="p-6 bg-green-50 rounded-xl border border-green-100 text-center">
                            <i class="fas fa-cloud-download-alt text-4xl text-green-500 mb-4"></i>
                            <h3 class="text-xl font-bold mb-2">تصدير البيانات</h3>
                            <p class="text-gray-600 mb-6 text-sm">حفظ نسخة من جميع بيانات العائلة على جهازك</p>
                            <div class="space-x-2 space-x-reverse">
                                <button @click="exportExcel" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded shadow transition-colors"><i class="fas fa-file-excel ml-1"></i> Excel</button>
                                <button @click="exportCSV" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded shadow transition-colors"><i class="fas fa-file-csv ml-1"></i> CSV</button>
                                <button @click="exportPDF" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded shadow transition-colors"><i class="fas fa-file-pdf ml-1"></i> PDF</button>
                            </div>
                        </div>
                        <div class="p-6 bg-blue-50 rounded-xl border border-blue-100 text-center">
                            <i class="fas fa-cloud-upload-alt text-4xl text-blue-500 mb-4"></i>
                            <h3 class="text-xl font-bold mb-2">استيراد البيانات</h3>
                            <p class="text-gray-600 mb-6 text-sm">رفع ملف Excel أو CSV لإضافة الأعضاء دفعة واحدة</p>
                            <input type="file" id="fileImport" @change="handleImport" accept=".xlsx, .xls, .csv" class="hidden">
                            <label for="fileImport" class="cursor-pointer bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded shadow transition-colors inline-block">
                                <i class="fas fa-upload ml-1"></i> اختر ملف البيانات
                            </label>
                        </div>
                    </div>
                </div>
            </transition>
        </main>

        <!-- نافذة عرض التفاصيل Modal -->
        <div v-if="selectedMember" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
            <div class="bg-white rounded-2xl w-full max-w-2xl shadow-2xl overflow-hidden fade-enter-active">
                <div class="bg-gradient-to-r from-green-600 to-green-500 p-4 text-white flex justify-between items-center">
                    <h3 class="text-xl font-bold">بطاقة تعريف العضو</h3>
                    <button @click="selectedMember = null" class="text-white hover:text-gray-200"><i class="fas fa-times text-xl"></i></button>
                </div>
                <div class="p-6 grid grid-cols-2 gap-4 text-sm">
                    <div><span class="text-gray-500 block">الاسم الكامل:</span><span class="font-bold">{{ selectedMember.firstName }} {{ selectedMember.fatherName }} {{ selectedMember.grandName }} {{ selectedMember.familyName }}</span></div>
                    <div><span class="text-gray-500 block">رقم الهوية:</span><span class="font-bold">{{ selectedMember.nationalId || 'غير مدون' }}</span></div>
                    <div><span class="text-gray-500 block">الجنس:</span><span class="font-bold">{{ selectedMember.gender }}</span></div>
                    <div><span class="text-gray-500 block">فصيلة الدم:</span><span class="font-bold text-red-500">{{ selectedMember.bloodType }}</span></div>
                    <div><span class="text-gray-500 block">تاريخ الميلاد ({{ selectedMember.dobType }}):</span><span class="font-bold">{{ selectedMember.dob || 'غير مدون' }}</span></div>
                    <div><span class="text-gray-500 block">رقم الهاتف:</span><span class="font-bold" dir="ltr">{{ selectedMember.phone || 'غير مدون' }}</span></div>
                    <div class="col-span-2">
                        <span class="text-gray-500 block">الحالة الاجتماعية:</span>
                        <span class="font-bold">{{ selectedMember.maritalStatus }} 
                            <span v-if="selectedMember.maritalStatus !== 'أعزب'" class="text-gray-600 font-normal">
                                (الأبناء: {{ selectedMember.childrenCount }} - بنين: {{ selectedMember.maleChildren }}, بنات: {{ selectedMember.femaleChildren }})
                            </span>
                        </span>
                    </div>
                    <div><span class="text-gray-500 block">المهنة:</span><span class="font-bold">{{ selectedMember.profession || 'غير مدون' }}</span></div>
                    <div class="col-span-2"><span class="text-gray-500 block">العنوان:</span><span class="font-bold">{{ selectedMember.address || 'غير مدون' }}</span></div>
                    <div class="col-span-2 bg-gray-50 p-3 rounded border"><span class="text-gray-500 block">ملاحظات:</span><span>{{ selectedMember.notes || 'لا توجد' }}</span></div>
                </div>
                <div class="p-4 bg-gray-50 text-left border-t">
                    <button @click="selectedMember = null" class="bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded">إغلاق</button>
                </div>
            </div>
        </div>
    </div>

    <!-- كود الـ Vue 3 -->
    <script>
        const { createApp, ref, computed, onMounted, watch } = Vue;

        createApp({
            setup() {
                const tabs = [
                    { id: 'dashboard', name: 'لوحة التحكم', icon: 'fas fa-chart-pie' },
                    { id: 'add', name: 'إضافة عضو', icon: 'fas fa-plus-circle' },
                    { id: 'list', name: 'قائمة الأعضاء', icon: 'fas fa-users' },
                    { id: 'export', name: 'استيراد وتصدير', icon: 'fas fa-sync' }
                ];
                
                const hijriMonths = ['محرم', 'صفر', 'ربيع الأول', 'ربيع الآخر', 'جمادى الأولى', 'جمادى الآخرة', 'رجب', 'شعبان', 'رمضان', 'شوال', 'ذو القعدة', 'ذو الحجة'];
                const hijriYears = Array.from({length: 151}, (_, i) => 1450 - i); 
                
                const gregorianMonths = ['يناير', 'فبراير', 'مارس', 'أبريل', 'مايو', 'يونيو', 'يوليو', 'أغسطس', 'سبتمبر', 'أكتوبر', 'نوفمبر', 'ديسمبر'];
                const currentYear = new Date().getFullYear();
                const gregorianYears = Array.from({length: 130}, (_, i) => currentYear - i);

                const activeTab = ref('dashboard');
                const members = ref([]);
                const currentHijriDate = ref('');
                const searchQuery = ref('');
                const selectedMember = ref(null);

                const getEmptyForm = () => ({
                    firstName: '', fatherName: '', grandName: '', familyName: '',
                    gender: 'ذكر', bloodType: 'O+', dobType: 'هجري', 
                    dobHijri: { day: 1, month: 'محرم', year: 1400 }, 
                    dobGregorian: { day: 1, month: 'يناير', year: 1990 },
                    nationalId: '', phone: '', profession: '',
                    maritalStatus: 'أعزب', maleChildren: 0, femaleChildren: 0, address: '', notes: ''
                });

                const form = ref(getEmptyForm());

                const totalChildren = computed(() => {
                    const males = parseInt(form.value.maleChildren) || 0;
                    const females = parseInt(form.value.femaleChildren) || 0;
                    return males + females;
                });

                const stats = computed(() => {
                    const lU = localStorage.getItem('hammad_last_update');
                    return {
                        total: members.value.length,
                        males: members.value.filter(m => m.gender === 'ذكر').length,
                        females: members.value.filter(m => m.gender === 'أنثى').length,
                        lastUpdate: lU ? lU : 'لم يتم التحديث بعد'
                    }
                });

                const filteredMembers = computed(() => {
                    if(!searchQuery.value) return members.value;
                    const q = searchQuery.value.toLowerCase();
                    return members.value.filter(m => 
                        (m.firstName + ' ' + m.familyName).toLowerCase().includes(q) ||
                        (m.phone && m.phone.includes(q)) ||
                        (m.nationalId && m.nationalId.includes(q))
                    );
                });

                // دالة محدثة تستخدم التقويم المدمج في المتصفح للحصول على التقويم الهجري بدقة أم القرى
                const updateTime = () => {
                    const now = new Date();
                    // استخدام خيارات النظام لطباعة التاريخ الهجري (مثال: 15 رمضان 1447)
                    const options = { year: 'numeric', month: 'long', day: 'numeric', calendar: 'islamic-umalqura' };
                    // إضافة '-u-nu-latn' لعرض الأرقام بصيغة لاتينية (1,2,3) بدلاً من الهندية (١,٢,٣)
                    const formatter = new Intl.DateTimeFormat('ar-SA-u-nu-latn', options);
                    currentHijriDate.value = formatter.format(now);
                };

                onMounted(() => {
                    const saved = localStorage.getItem('hammad_members');
                    if (saved) members.value = JSON.parse(saved);
                    updateTime();
                    // تحديث التاريخ كل ساعة
                    setInterval(updateTime, 3600000);
                });

                watch(members, (newVal) => {
                    localStorage.setItem('hammad_members', JSON.stringify(newVal));
                    localStorage.setItem('hammad_last_update', new Date().toLocaleString('ar-SA'));
                }, { deep: true });

                const saveMember = () => {
                    const finalDob = form.value.dobType === 'هجري' 
                        ? `${form.value.dobHijri.day} ${form.value.dobHijri.month} ${form.value.dobHijri.year}`
                        : `${form.value.dobGregorian.day} ${form.value.dobGregorian.month} ${form.value.dobGregorian.year}`;

                    const newMember = { 
                        ...form.value, 
                        dob: finalDob,
                        childrenCount: form.value.maritalStatus !== 'أعزب' ? totalChildren.value : 0,
                        id: Date.now() 
                    };

                    members.value.unshift(newMember);
                    form.value = getEmptyForm();
                    activeTab.value = 'list';
                    Swal.fire({ icon: 'success', title: 'تم الحفظ', text: 'تمت إضافة العضو بنجاح', confirmButtonColor: '#22c55e' });
                };

                const deleteMember = (id) => {
                    Swal.fire({
                        title: 'هل أنت متأكد؟', text: "لن تتمكن من التراجع عن هذا الإجراء!",
                        icon: 'warning', showCancelButton: true,
                        confirmButtonColor: '#ef4444', cancelButtonColor: '#6b7280',
                        confirmButtonText: 'نعم، احذف!', cancelButtonText: 'إلغاء'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            members.value = members.value.filter(m => m.id !== id);
                            Swal.fire({ icon: 'success', title: 'تم الحذف', text: 'تم حذف العضو.', confirmButtonColor: '#22c55e' });
                        }
                    });
                };

                const viewMember = (member) => { selectedMember.value = member; };

                const exportExcel = () => {
                    if(members.value.length === 0) return Swal.fire('تنبيه','لا توجد بيانات لتصديرها','info');
                    const ws = XLSX.utils.json_to_sheet(members.value);
                    const wb = XLSX.utils.book_new();
                    XLSX.utils.book_append_sheet(wb, ws, "شجرة العائلة");
                    XLSX.writeFile(wb, "صندوق_عائلة_الحماد.xlsx");
                };

                const exportCSV = () => {
                    if(members.value.length === 0) return Swal.fire('تنبيه','لا توجد بيانات لتصديرها','info');
                    const ws = XLSX.utils.json_to_sheet(members.value);
                    const csv = XLSX.utils.sheet_to_csv(ws);
                    const blob = new Blob(["\uFEFF"+csv], {type: 'text/csv;charset=utf-8;'});
                    const link = document.createElement("a");
                    link.href = URL.createObjectURL(blob);
                    link.download = "صندوق_عائلة_الحماد.csv";
                    link.click();
                };

                const exportPDF = () => {
                    if(members.value.length === 0) return Swal.fire('تنبيه','لا توجد بيانات لتصديرها','info');
                    Swal.fire({ title: 'جاري تجهيز PDF...', timer: 1500, didOpen: () => Swal.showLoading() });
                    const element = document.getElementById('membersTable');
                    html2pdf().from(element).set({
                        margin: 10, filename: 'سجل_عائلة_الحماد.pdf', html2canvas: { scale: 2 },
                        jsPDF: { orientation: 'landscape', unit: 'mm', format: 'a4', compress: true }
                    }).save();
                };

                const handleImport = (e) => {
                    const file = e.target.files[0];
                    if(!file) return;
                    const reader = new FileReader();
                    reader.onload = (evt) => {
                        try {
                            const bstr = evt.target.result;
                            const wb = XLSX.read(bstr, {type:'binary'});
                            const wsname = wb.SheetNames[0];
                            const data = XLSX.utils.sheet_to_json(wb.Sheets[wsname]);
                            
                            const newMembers = data.map(item => ({...item, id: Date.now() + Math.random()}));
                            members.value = [...newMembers, ...members.value];
                            
                            Swal.fire('نجاح!', `تم استيراد ${newMembers.length} عضو بنجاح`, 'success');
                            e.target.value = null;
                        } catch (err) {
                            Swal.fire('خطأ!', 'فشل قراءة الملف، تأكد من الصيغة.', 'error');
                        }
                    };
                    reader.readAsBinaryString(file);
                };

                return {
                    tabs, activeTab, members, stats, currentHijriDate, searchQuery, filteredMembers,
                    form, hijriMonths, hijriYears, gregorianMonths, gregorianYears, totalChildren, 
                    saveMember, deleteMember, selectedMember, viewMember,
                    exportExcel, exportCSV, exportPDF, handleImport
                };
            }
        }).mount('#app');
    </script>
</body>
</html>
